{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../rspack/src",
    "lib": ["es2022", "dom"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "emitDeclarationOnly": true,
    "sourceMap": false,
    "declarationMap": false
  },
  "include": ["../rspack/src", "../rspack/src/**/*.json"],
  "exclude": ["../rspack/src/container/default.runtime.js"]
}
