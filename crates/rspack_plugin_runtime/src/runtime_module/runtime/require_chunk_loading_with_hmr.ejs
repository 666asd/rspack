function loadUpdateChunk(chunkId, updatedModulesList) {
	var update = require("./" + <%- GET_CHUNK_UPDATE_SCRIPT_FILENAME %>(chunkId));
	var updatedModules = update.modules;
	var runtime = update.runtime;
	for (var moduleId in updatedModules) {
		if (<%- HAS_OWN_PROPERTY %>(updatedModules, moduleId)) {
			currentUpdate[moduleId] = updatedModules[moduleId];
			if (updatedModulesList) updatedModulesList.push(moduleId);
		}
	}
	<% if (_with_runtime_proxy) { %>if(typeof update.<%- VAR_EXTERNAL_RUNTIME_PROXY %> === "function") update.<%- VAR_EXTERNAL_RUNTIME_PROXY %>(<%- VAR_RUNTIME_PROXY %>);
	<% } %>
	if (runtime) currentUpdateRuntime.push(runtime);
}
